{
  "name": "iem-base-station-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "start:cloud": "CLOUD_ONLY=1 node server/index.js",
    "start:emulator": "EMULATOR=1 node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node --test",
    "tunnel": "npm run tunnel:cloudflare",
    "tunnel:cloudflare": "cloudflared tunnel --url http://localhost:3000",
    "tunnel:ngrok": "ngrok http 3000"
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "serialport": "^12.0.0",
    "ws": "^8.17.1"
  }
}
